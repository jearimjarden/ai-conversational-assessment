# --- Application ---
DEBUG=false

# --- Database ---
# SQLAlchemy URL. When running via docker-compose the host is "db".
DATABASE_URL=postgresql+psycopg://assessment:assessment@localhost:5432/assessment

# --- OpenAI ---
OPENAI_API_KEY=sk-your-key-here
# The design docs reference "GPT-5.5" (which does not exist). Set a real model id.
OPENAI_MODEL=gpt-4o

# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000
